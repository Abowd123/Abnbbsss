TELEGRAM_BOT_TOKEN=   #توكنك
DEEPSEEK_API_KEY=   #مفتاح
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.2
# فعّلها فقط مع موديلات التفكير (deepseek-reasoner / v4-pro)، وارفع MAX_TOKENS معها.
DEEPSEEK_THINKING=false
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_ENABLED=true

# يُستخدم تلقائياً إذا غاب DeepSeek أو فشل (Timeout / Rate limit / خطأ / توقف).
GROQ_API_KEY=    #مفتاح
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=32768
GROQ_TEMPERATURE=0.2
GROQ_ENABLED=true

# priority = DeepSeek أولاً ثم Groq   |   fastest = الأسرع استجابةً أولاً
AI_ROUTING=priority
# فحص صحة دوري بالثواني (0 = إيقاف). يعيد المزود المتعافي إلى الخدمة تلقائياً.
AI_HEALTH_INTERVAL=300
AI_PROBE_TIMEOUT=15
AI_TEMPERATURE=0.2

REQUEST_TIMEOUT=600
MAX_RETRIES=3
RETRY_DELAY=2.0
VALIDATION_RETRIES=1

MAX_FILE_SIZE=200000
MAX_ARCHIVE_SIZE=15000000
MAX_ARCHIVE_ENTRIES=2000
MAX_EXTRACTED_SIZE=25000000
MAX_PROJECT_FILES=20
PROJECT_PARALLELISM=3
MAX_CONTEXT_FILES=6
MAX_CONTEXT_CHARS=40000
MAX_CHUNKS=24
MAX_CONCURRENT_JOBS=4
MAX_HISTORY=10
USER_COOLDOWN=1.0

# فارغ = البوت متاح للجميع. أرقام مفصولة بفواصل = قائمة سماح (الاشتراك).
ALLOWED_USER_IDS=
# مطلوب لأمر /ai_status. فارغ = لا أحد مشرف.
ADMIN_IDS=   #ايديك
LOG_DIR=logs
LOG_TO_FILE=true
LOG_LEVEL=INFO
